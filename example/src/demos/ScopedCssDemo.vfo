/**
 * 说明：用于关闭对 `.vfo` 文件的 TypeScript 类型检查（避免编辑器对 JSX 运行时的误判）
 */
// @ts-nocheck
export const css = `
.box {
  padding: 16px;
  border: 1px dashed #94a3b8;
  border-radius: 12px;
}

.tip {
  color: #64748b;
}
`

/**
 * 演示：在 `.vfo` 文件中使用 `export const css = \`...\`` 声明样式，并自动作用域隔离
 */
export default () => {
  return (
    <div class="box">
      <h2>样式隔离</h2>
      <p class="tip">此样式只作用于当前组件的根节点作用域内。</p>
    </div>
  )
}
